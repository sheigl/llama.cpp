#!/bin/bash
MODEL_PATH=${MODEL_PATH:-/mnt/1TB/AI/chat_models}
MODEL=${MODEL:-Qwen_Qwen3.5-35B-A3B-Q6_K.gguf}
MODEL_ALIAS=${MODEL_ALIAS:-qwen3.5:35b-a3b}
PORT=${PORT:-8080}
BUILD_DIR=${BUILD_DIR:-build-sycl}
BATCH_SIZE=${BATCH_SIZE:-2048}
UBATCH_SIZE=${UBATCH_SIZE:-1024}
CONTEXT_SIZE=${CONTEXT_SIZE:-65536}
CACHE_TYPE=${CACHE_TYPE:-q8_0}
CPU_MOE=${CPU_MOE:-3}
MMAP=${MMAP:-no-}

if [[ "$BUILD_DIR" == *"sycl"* ]]; then
    source /opt/intel/oneapi/setvars.sh
    export ZES_ENABLE_SYSMAN=1
    export GGML_SYCL_VISIBLE_DEVICES=0,1,2
    echo "SYSMAN ENABLED"
fi

if [[ "$BUILD_DIR" == *"openvino"* ]]; then
   source /opt/intel/openvino/setupvars.sh
   export GGML_OPENVINO_DEVICE=GPU.0
   echo "USING OPENVINO"
fi

if [[ "$BUILD_DIR" == *"vulkan"* ]]; then
   echo "USING VULKAN"
fi

/mnt/1TB/AI/llama.cpp/$BUILD_DIR/bin/llama-server \
    --model "$MODEL_PATH/$MODEL" \
    --jinja \
    --alias $MODEL_ALIAS \
    --port $PORT \
    --${MMAP}mmap \
    --host 0.0.0.0 \
    --fit on \
    --n-cpu-moe $"$CPU_MOE"
    -ngl 999 \
    -np 1 \
    -fa on \
    -ctv "$CACHE_TYPE" \
    -ctk "$CACHE_TYPE" \
    -t 4 \
    -sm layer \
    --batch-size "$BATCH_SIZE" \
    --ubatch-size "$UBATCH_SIZE" \
    --reasoning on \
    --tensor-split 3,3,3 \
    -c "$CONTEXT_SIZE" \
    2>&1 | tee /tmp/llama-8080.log
