#!/bin/bash
MODEL_PATH=${MODEL_PATH:-/mnt/1TB/AI/chat_models}
MODEL=${MODEL:-Qwen3.6-35B-A3B-UD-Q4_K_M.gguf}
MODEL_ALIAS=${MODEL_ALIAS:-qwen3.6:35b-a3b}
PORT=${PORT:-8080}
BUILD_DIR=${BUILD_DIR:-build-sycl}
BATCH_SIZE=${BATCH_SIZE:-4096}
UBATCH_SIZE=${UBATCH_SIZE:-2048}
CONTEXT_SIZE=${CONTEXT_SIZE:-81920}
CACHE_TYPE=${CACHE_TYPE:-q8_0}
NGL=${NGL:-99}
MMAP=${MMAP:-mmap}
FLASH_ATTN=${FLASH_ATTN:-on}
MMPROJ=${MMPROJ:-mmproj-Qwen_Qwen3.5-35B-A3B-f16.gguf}
REASONING=${REASONING:-on}
NP=${NP:-1}

if [[ "$BUILD_DIR" == *"sycl"* ]]; then
    source /opt/intel/oneapi/setvars.sh
    export ZES_ENABLE_SYSMAN=1
    #export GGML_SYCL_DISABLE_OPT=1
    export GGML_SYCL_VISIBLE_DEVICES=0,1,2
    echo "SYSMAN ENABLED"
fi

if [[ "$BUILD_DIR" == *"openvino"* ]]; then
   source /opt/intel/openvino/setupvars.sh
   export GGML_OPENVINO_DEVICE=GPU.0
   echo "USING OPENVINO"
fi

if [[ "$BUILD_DIR" == *"vulkan"* ]]; then
   echo "USING VULKAN"
fi

/mnt/1TB/AI/llama.cpp/$BUILD_DIR/bin/llama-server \
    --model "$MODEL_PATH/$MODEL" \
    --jinja \
    --alias $MODEL_ALIAS \
    --port $PORT \
    --$MMAP \
    --host 0.0.0.0 \
    --fit on \
    -ngl "$NGL" \
    -fa "$FLASH_ATTN" \
    -ctv "$CACHE_TYPE" \
    -ctk "$CACHE_TYPE" \
    --swa-full \
    -t 8 \
    -np "$NP" \
    -sm layer \
    --batch-size "$BATCH_SIZE" \
    --ubatch-size "$UBATCH_SIZE" \
    --chat-template-kwargs '{"preserve_thinking": true}' \
    --reasoning "$REASONING" \
    -c "$CONTEXT_SIZE" \
    2>&1 | tee /tmp/llama-8080.log
